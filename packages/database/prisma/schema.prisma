generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gallery {
  id           Int             @id @default(autoincrement())
  name         String          @default("CEF MOTORS")
  address      String          @default("")
  phone        String          @default("")
  email        String          @default("")
  workingHours String          @default("")
  about        String          @default("")
  logoUrl      String?
  mapsUrl      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  teamMembers  TeamMember[]
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  galleryId Int      @default(1)
  name      String
  title     String
  photo     String?
  phone     String?
  email     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}

model Car {
  id              Int        @id @default(autoincrement())
  brand           String
  model           String
  year            Int
  price           Float
  currency        String     @default("TL")
  mileage         Int?
  fuelType        String?
  transmission    String?
  color           String?
  enginePower     String?
  description     String     @default("")
  status          String     @default("available")
  isFeatured      Boolean    @default(false)
  isPublished     Boolean    @default(false)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  images          CarImage[]
  videos          CarVideo[]
  contactMessages ContactMessage[]
}

model CarImage {
  id        Int      @id @default(autoincrement())
  carId     Int
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model CarVideo {
  id        Int      @id @default(autoincrement())
  carId     Int
  url       String
  title     String?
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  carId     Int?
  carBrand  String?
  carModel  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  car       Car?     @relation(fields: [carId], references: [id], onDelete: SetNull)
}

model AdminUser {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
}
